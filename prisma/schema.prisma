generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  projects Project[]
}

model Project {
  id          String        @id @default(cuid())
  projectNo   String        @unique
  projectName String
  customer    String
  status      ProjectStatus @default(DRAFT)

  language           String
  projectDate        DateTime
  industry           String
  implementationType String
  systemType         String
  preparedBy         String
  version            String
  notes              String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  scopeAnswers ScopeAnswer[]
  modules      ProjectModule[]
  localizations ProjectLocalization[]
  developments ProjectDevelopment[]
  hypercareItems ProjectHypercare[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScopeAnswer {
  id        String   @id @default(cuid())
  projectId String
  question  String
  answer    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectModule {
  id        String   @id @default(cuid())
  projectId String
  module    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectLocalization {
  id        String   @id @default(cuid())
  projectId String
  country   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectDevelopment {
  id          String   @id @default(cuid())
  projectId   String
  type        String
  description String
  quantity    Int
  complexity  String
  effort      Int
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectHypercare {
  id        String   @id @default(cuid())
  projectId String
  item      String
  effort    Int
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

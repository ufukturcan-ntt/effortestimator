generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  projects Project[]
}

model Project {
  id          String        @id @default(cuid())
  projectNo   String        @unique
  projectName String
  customer    String
  status      ProjectStatus @default(DRAFT)

  language           String
  projectDate        DateTime
  industry           String
  implementationType String
  systemType         String
  preparedBy         String
  version            String
  notes              String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  scopeAnswers ScopeAnswer[]
  modules      ProjectModule[]
  localizations ProjectLocalization[]
  developments ProjectDevelopment[]
  hypercareItems ProjectHypercare[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScopeAnswer {
  id        String   @id @default(cuid())
  projectId String
  question  String
  answer    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectModule {
  id        String   @id @default(cuid())
  projectId String
  module    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectLocalization {
  id        String   @id @default(cuid())
  projectId String
  country   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectDevelopment {
  id          String   @id @default(cuid())
  projectId   String
  type        String
  description String
  quantity    Int
  complexity  String
  effort      Int
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model ProjectHypercare {
  id        String   @id @default(cuid())
  projectId String
  item      String
  effort    Int
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model EffortCatalogue {
  id        String   @id @default(cuid())
  category  String
  code      String
  name      String
  effort    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([category, code])
}

model SelectionOption {
  id        String   @id @default(cuid())
  category  String
  value     String
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([category, value])
}

model ScopeQuestion {
  id                 String   @id @default(cuid())
  code               String   @unique
  category           String
  question           String
  answerType         String
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)

  industry           String?
  implementationType String?
  systemType         String?

  createdAt DateTime @default(now())

  options ScopeQuestionOption[]
}

model ScopeQuestionOption {
  id         String @id @default(cuid())
  questionId String

  value      String
  label      String
  effort     Int @default(0)
  sortOrder  Int @default(0)

question ScopeQuestion @relation(
  fields: [questionId],
  references: [id]
)
}
